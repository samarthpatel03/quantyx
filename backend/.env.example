# MongoDB Connection
MONGODB_URI=mongodb+srv://<username>:<password>@quantyx-cluster.xxxxx.mongodb.net/quantyx?retryWrites=true&w=majority

# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_secret_key_here_generate_a_secure_random_string

# Server Port
PORT=3001

# Gemini API Key (for Advisor MVP)
GEMINI_API_KEY=your_gemini_api_key_here

# NSE API (if using paid API)
NSE_API_KEY=optional_if_using_paid_nse_api
